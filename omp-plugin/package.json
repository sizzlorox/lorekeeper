{
  "name": "@lorekeeper/omp-plugin",
  "version": "0.1.0",
  "description": "lorekeeper bindings for the oh-my-pi coding agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "omp": {
    "extensions": ["./dist/index.js"]
  },
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@oh-my-pi/pi-coding-agent": "^15.1.3",
    "@types/bun": "^1.2.0",
    "typescript": "^5.6.0"
  }
}
