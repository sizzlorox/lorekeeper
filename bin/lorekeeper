#!/usr/bin/env bash
# lorekeeper CLI — lightweight wrapper around qmd + filesystem operations.

set -euo pipefail

CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
LOREKEEPER_HOME="$(cat "$CLAUDE_DIR/.lorekeeper-home" 2>/dev/null || echo "$HOME/.local/share/lorekeeper")"

# shellcheck disable=SC2016  # $EDITOR / $LOREKEEPER_HOME are literal in help text
USAGE='lorekeeper <command> [args]

  status              install health check
  add-repo <name>     create notes/<name>/ and docs/<name>/ plus a qmd context
  note <repo> <slug>  open $EDITOR on a note (creates from template if missing)
  doc  <repo> <slug>  same, for docs
  ls [repo]           list notes/docs (optionally scoped to one repo)
  reindex             force qmd update + embed
  distill [repo]      synthesize durable docs (architecture/runbook/onboarding/
                      conventions/api) from notes + codebase. Run from the
                      repo root; arg defaults to the current git toplevel name.
                      Uses Sonnet + tools; can take minutes and cost a few $.
  skipped [repo]      review sessions the classifier discarded (→ none)
  validate <repo>     list notes not updated in 90+ days; open for review
  home                print $LOREKEEPER_HOME
  help                this message
'

die() { printf "xx %s\n" "$*" >&2; exit 1; }

cmd="${1:-help}"
shift || true

# Locate the installed template so `note` / `doc` can seed new files.
# install.sh runs from the repo root; we stash a breadcrumb there.
TEMPLATE_NOTE="$LOREKEEPER_HOME/.template-note.md"

ensure_template() {
  if [[ ! -f "$TEMPLATE_NOTE" ]]; then
    cat > "$TEMPLATE_NOTE" <<'TPL'
---
repo: __REPO__
topic: __SLUG__
date: __DATE__
updated: __DATE__
tags: []
---

# __TITLE__

## context
<when/why this came up — 1-3 sentences>

## what i learned
<the actual content — bullets for gotchas, code refs as file:line>

## see also
<relative links or qmd:// refs>
TPL
  fi
}

open_editor() {
  local f="$1"
  "${EDITOR:-${VISUAL:-vi}}" "$f"
}

open_file() {
  local kind="$1" repo="$2" slug="$3"
  [[ -n "$repo" ]] || die "repo name required"
  [[ -n "$slug" ]] || die "slug required"
  local dir="$LOREKEEPER_HOME/$kind/$repo"
  mkdir -p "$dir"
  local file="$dir/$slug.md"
  if [[ ! -f "$file" ]]; then
    ensure_template
    sed \
      -e "s|__REPO__|$repo|g" \
      -e "s|__SLUG__|$slug|g" \
      -e "s|__DATE__|$(date +%F)|g" \
      -e "s|__TITLE__|$slug|g" \
      "$TEMPLATE_NOTE" > "$file"
  fi
  open_editor "$file"
  # Best-effort reindex (foreground, short)
  ( qmd update && qmd embed ) >/dev/null 2>&1 || true
}

case "$cmd" in
  home) echo "$LOREKEEPER_HOME" ;;

  help|-h|--help) printf '%s' "$USAGE" ;;

  status)
    printf "home:        %s\n" "$LOREKEEPER_HOME"
    printf "qmd:         "
    if command -v qmd >/dev/null; then printf "installed (%s)\n" "$(qmd --version 2>/dev/null || echo 'unknown')"
    else printf "NOT FOUND\n"; fi
    printf "collections: "
    qmd collection list 2>/dev/null | grep -E "lorekeeper-(notes|docs)" || echo "(none registered)"
    printf "\nhooks:\n"
    for h in lorekeeper-prime.sh lorekeeper-reindex.sh lorekeeper-autonote.sh; do
      if [[ -x "$CLAUDE_DIR/hooks/$h" ]]; then printf "  %s\n" "$h ✓"
      else printf "  %s\n" "$h MISSING"; fi
    done
    printf "\nautonote: "
    if [[ -e "$LOREKEEPER_HOME/.autonote-off" ]] || [[ "${LOREKEEPER_AUTONOTE:-on}" == "off" ]]; then
      echo "disabled"
    else
      echo "enabled"
    fi
    printf "\nCLAUDE.md policy block: "
    if grep -qF "<!-- LOREKEEPER:START -->" "$CLAUDE_DIR/CLAUDE.md" 2>/dev/null; then
      echo "present"
    else
      echo "MISSING"
    fi
    printf "caveman:     "
    if command -v claude >/dev/null && claude plugin list 2>/dev/null | grep -qi caveman; then
      echo "active"
    else
      echo "not installed"
    fi
    ;;

  add-repo)
    name="${1:-}"; [[ -n "$name" ]] || die "usage: lorekeeper add-repo <name>"
    mkdir -p "$LOREKEEPER_HOME/notes/$name" "$LOREKEEPER_HOME/docs/$name"
    qmd context add "qmd://lorekeeper-notes/$name" "Memory for repo '$name'" 2>/dev/null || true
    qmd context add "qmd://lorekeeper-docs/$name"  "Reference docs for repo '$name'" 2>/dev/null || true
    echo "registered '$name'"
    ;;

  note) open_file notes "${1:-}" "${2:-}" ;;
  doc)  open_file docs  "${1:-}" "${2:-}" ;;

  ls)
    repo="${1:-}"
    if [[ -n "$repo" ]]; then
      for kind in notes docs; do
        d="$LOREKEEPER_HOME/$kind/$repo"
        [[ -d "$d" ]] || continue
        printf "\n== %s/%s ==\n" "$kind" "$repo"
        find "$d" -type f -name '*.md' 2>/dev/null | sed "s|^$d/|  |" | sort
      done
    else
      for kind in notes docs; do
        printf "\n== %s ==\n" "$kind"
        if [[ -d "$LOREKEEPER_HOME/$kind" ]]; then
          for r in "$LOREKEEPER_HOME/$kind"/*/; do
            [[ -d "$r" ]] || continue
            repo="$(basename "$r")"
            count="$(find "$r" -type f -name '*.md' 2>/dev/null | wc -l | tr -d ' ')"
            printf "  %-30s %s file(s)\n" "$repo" "$count"
          done
        fi
      done
    fi
    ;;

  reindex)
    qmd update && qmd embed
    ;;

  skipped)
    repo_filter="${1:-}"
    skipped_log="$LOREKEEPER_HOME/.skipped.log"
    if [[ ! -f "$skipped_log" ]]; then
      echo "(no skipped sessions logged yet)"
    elif [[ -n "$repo_filter" ]]; then
      grep $'\t'"$repo_filter"$'\t' "$skipped_log" 2>/dev/null \
        || echo "(no skipped sessions for '$repo_filter')"
    else
      cat "$skipped_log"
    fi
    ;;

  validate)
    repo="${1:-}"; [[ -n "$repo" ]] || die "usage: lorekeeper validate <repo>"
    notes_dir="$LOREKEEPER_HOME/notes/$repo"
    [[ -d "$notes_dir" ]] || die "no notes for repo '$repo'"
    stale_cutoff="$(date -d "90 days ago" +%Y-%m-%d 2>/dev/null \
      || date -v-90d +%Y-%m-%d 2>/dev/null \
      || die "cannot compute date; check your OS date command")"
    stale_files=()
    while IFS= read -r -d '' f; do
      note_date="$(grep -m1 '^updated:' "$f" 2>/dev/null | sed 's/^updated:[[:space:]]*//')"
      [[ -z "$note_date" ]] && note_date="$(grep -m1 '^date:' "$f" 2>/dev/null | sed 's/^date:[[:space:]]*//')"
      if [[ -n "$note_date" && "$note_date" < "$stale_cutoff" ]]; then
        stale_files+=("$f")
        printf "STALE (%s): %s\n" "$note_date" "$(basename "$f")"
      fi
    done < <(find "$notes_dir" -maxdepth 1 -type f -name '*.md' -print0 2>/dev/null)
    if [[ "${#stale_files[@]}" -eq 0 ]]; then
      echo "No stale notes for '$repo' (90-day threshold)."
    else
      printf "\n%d stale note(s). Edit each and bump 'updated:' to mark validated.\n" "${#stale_files[@]}"
      printf "Open all for review? [y/N] "
      read -r answer
      if [[ "$answer" =~ ^[Yy] ]]; then
        for f in "${stale_files[@]}"; do
          open_editor "$f"
        done
      fi
    fi
    ;;

  distill)
    command -v claude >/dev/null || die "claude CLI not on PATH"
    here="$(pwd)"
    toplevel="$(git -C "$here" rev-parse --show-toplevel 2>/dev/null || true)"
    [[ -n "$toplevel" ]] || die "run this from inside a git worktree"
    repo_arg="${1:-$(basename "$toplevel")}"
    if [[ "$(basename "$toplevel")" != "$repo_arg" ]]; then
      die "current git toplevel is '$(basename "$toplevel")', not '$repo_arg' — cd into that worktree first"
    fi
    repo="$repo_arg"
    notes_dir="$LOREKEEPER_HOME/notes/$repo"
    docs_dir="$LOREKEEPER_HOME/docs/$repo"
    mkdir -p "$docs_dir"

    cat <<INFO
==> distilling durable docs for '$repo'
    notes:  $notes_dir
    docs:   $docs_dir
    (this spawns Sonnet with Read/Glob/Grep/Write; may take minutes)
INFO

    prompt="You are generating durable engineering documentation for the repo at the current working directory (name: $repo).

INPUTS:
- Scratch notes are in: $notes_dir (use Read/Glob to enumerate and load)
- Repo source is at the current working directory (use Glob/Grep/Read)

OUTPUTS (write each with the Write tool, only if you have substantive content):
- $docs_dir/architecture.md   — system design, major components, data flow, key entry points
- $docs_dir/onboarding.md     — getting started, env setup, first contribution walkthrough
- $docs_dir/runbook.md        — ops procedures, deploy, rollback, debugging production
- $docs_dir/conventions.md    — coding style, naming, patterns, testing conventions
- $docs_dir/api.md            — public API reference (endpoints, types, commands); skip if the repo has no public surface

SAFETY:
- DO NOT modify any files outside $docs_dir. Never Edit or Write into the repo source tree.
- If a target doc contains a block delimited by <!-- AUTODOC:START --> and <!-- AUTODOC:END -->, only rewrite content INSIDE those sentinels. Preserve everything outside verbatim.
- If a target doc exists and has NO sentinels, treat it as hand-curated: read it, merge respectfully (add sections, refine existing prose), do not wholesale replace it.

METHOD:
1. First, list and skim all notes under $notes_dir.
2. Then scan the repo structure: top-level files, package/module layout, entry points, README, tests, CI config.
3. For each target doc, write content only if you have substantive grounded material. If you lack evidence for a section, omit it. Do NOT hallucinate features, endpoints, or configs.
4. Prefer concrete references: cite files as \`path:line\` or \`path\`. Show real commands, not placeholders.
5. Keep prose terse: drop articles, fragments ok, technical identifiers exact.

OUTPUT DISCIPLINE:
- Each file starts with YAML frontmatter: \`repo: $repo\`, \`type: <architecture|onboarding|runbook|conventions|api>\`, \`updated: $(date +%Y-%m-%d)\`.
- Use a single H1 matching the doc type, then H2 sections.
- When you finish, print a one-line summary of which files you wrote or updated."

    LOREKEEPER_AUTONOTE_CHILD=1 claude -p "$prompt" \
      --model claude-sonnet-4-6 \
      --add-dir "$docs_dir" --add-dir "$notes_dir" \
      --allowed-tools "Read,Glob,Grep,Write" \
      --permission-mode bypassPermissions

    ( qmd update && qmd embed ) >/dev/null 2>&1 || true

    # Clear distill-pending flag and update watermark.
    pending_flag="$LOREKEEPER_HOME/.distill-pending/$repo"
    [[ -f "$pending_flag" ]] && rm -f "$pending_flag"
    notes_count="$(find "$LOREKEEPER_HOME/notes/$repo" -maxdepth 1 -type f -name '*.md' \
      2>/dev/null | wc -l | tr -d ' ')"
    watermark_dir="$LOREKEEPER_HOME/.distill-watermark"
    mkdir -p "$watermark_dir"
    echo "$notes_count" > "$watermark_dir/$repo"
    ;;

  *) die "unknown command: $cmd  (try: lorekeeper help)" ;;
esac
